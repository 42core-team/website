#!/usr/bin/env bash
set -e

ROOT="$(git rev-parse --show-toplevel)"
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

run_lint() {
  local dir="$1"
  echo "==> Running pnpm lint in $dir..."
  (cd "$ROOT/$dir" && pnpm lint)
}

if echo "$STAGED_FILES" | grep -q "^frontend/"; then
  run_lint frontend
fi

if echo "$STAGED_FILES" | grep -q "^api/"; then
  run_lint api
fi

if echo "$STAGED_FILES" | grep -q "^github-service/"; then
  run_lint github-service
fi
