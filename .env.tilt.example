# Copy this file to .env.tilt and fill in the values.
# .env.tilt is gitignored and never committed.
# All other dev credentials are hardcoded in tilt/local-values/*.yaml.

# GitHub OAuth app (create one at https://github.com/settings/developers)
# Callback URL: http://localhost:4000/auth/github/callback
CLIENT_GITHUB_ID=
CLIENT_GITHUB_SECRET=

# 42 OAuth app
# Callback URL: http://localhost:4000/auth/42/callback
FORTYTWO_CLIENT_ID=
FORTYTWO_CLIENT_SECRET=
